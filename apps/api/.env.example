# ============================================
# 阿里云 OSS 配置
# ============================================
# 阿里云 OSS 所在地域，例如：oss-cn-beijing
OSS_REGION=oss-cn-beijing

# 用于上传文件的 OSS Bucket 名称
OSS_BUCKET=your_bucket_name

# 具备上传权限的阿里云账号或 RAM 用户 AccessKey ID
OSS_ACCESS_KEY_ID=your_access_key_id

# 与 OSS_ACCESS_KEY_ID 配套的 AccessKey Secret
OSS_ACCESS_KEY_SECRET=your_access_key_secret

# RAM 角色 ARN
# 在阿里云 RAM 控制台 -> 角色管理 中查看
# 格式: acs:ram::账户ID:role/角色名
ROLE_ARN=acs:ram::your_account_id:role/your_role_name

# POST Policy / 表单直传配置
OSS_UPLOAD_DIR=post-demo/
OSS_POST_POLICY_EXPIRE_SECONDS=300
OSS_POST_POLICY_MAX_SIZE=5368709120
OSS_FORBID_OVERWRITE=true

# 服务端口（可选，默认 3000）
PORT=3000

# Unified AWS SDK v3 upload demo options
UPLOAD_MAX_SIZE=5368709120

# Optional public/CDN base URL. When set, /api/upload-token returns objectUrl.
PUBLIC_BASE_URL=

# S3-compatible multipart demo options.
# Bucket and Region reuse OSS_BUCKET / OSS_REGION above.
S3_ENDPOINT=https://s3.oss-cn-beijing.aliyuncs.com
S3_BASE_PATH=uploads/
# Optional. /api/s3-upload-complete uses this to generate publicUrl.
# Empty means https://<OSS_BUCKET>.<OSS_REGION>.aliyuncs.com
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
