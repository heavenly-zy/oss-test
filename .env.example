# 阿里云 OSS 所在地域，例如：oss-cn-beijing
OSS_REGION=oss-cn-beijing

# 用于上传文件的 OSS Bucket 名称
OSS_BUCKET=your-bucket-name

# 具备上传权限的阿里云账号或 RAM 用户 AccessKey ID
ACCESS_KEY_ID=your-access-key-id

# 与 ACCESS_KEY_ID 配套的 AccessKey Secret
ACCESS_KEY_SECRET=your-access-key-secret

# RAM 角色 ARN
# 在阿里云 RAM 控制台 -> 角色管理 中查看
# 格式: acs:ram::账户ID:role/角色名
ROLE_ARN=acs:ram::123456789:role/oss-uploader

# 服务端口
PORT=3000
